          "female": "{{name}} te invitó a pasear a su perra",
          "male": "{{name}} te invitó a pasear a su perro",
          "other": "{{name}} te invitó a pasear a su perro"
        }
      }
    }
  },
  "inbox": {
    "unread": {
      "$plural": {
        "one": "{{count}} mensaje sin leer",
        "other": "{{count}} mensajes sin leer"
      }
    }
  }
